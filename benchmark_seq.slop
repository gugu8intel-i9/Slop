fn heavy_task(x: int) -> int {
    let n = x
    let i = 0
    while i < 5000000 {
        n = (n + i) % 1000000007
        i = i + 1
    }
    return n
}

fn main(args: array[string]) {
    let arr = []
    let i = 0
    while i < 32 {
        push(arr, i + 1)
        i = i + 1
    }

    let total = 0
    i = 0
    while i < length(arr) {
        total = total + heavy_task(arr[i])
        i = i + 1
    }
    print("Sequential total:")
    print(total)
}
